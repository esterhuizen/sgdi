# Copy to .env (gitignored) and fill in. Or set via systemd EnvironmentFile=
# in production.

# ---- Solana RPC (Helius recommended; mainnet-beta works as a fallback) -----
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# ---- Validators.app (cross-reference for validator metadata) ---------------
# Get a token at https://www.validators.app/users/sign_up
VALIDATORS_APP_TOKEN=

# ---- Stakewiz (no auth required) -------------------------------------------
# STAKEWIZ_BASE_URL=https://api.stakewiz.com

# ---- Storage paths ---------------------------------------------------------
# Where the SQLite DB lives. /var/lib/sgdi/gdi.db in production; for local
# dev point at something gitignored under the project root.
SGDI_DB_PATH=./var/sgdi.db

# Where structured run logs are written (JSONL, one file per UTC date).
SGDI_LOG_DIR=./var/logs

# Where the published static JSON is generated. /var/lib/sgdi/published in
# production. The deploy step then symlinks current/public/gdi → here so
# nginx serves it.
SGDI_PUBLISHED_DIR=./var/published

# ---- Public site URL (used in metadata / OpenGraph) ------------------------
NEXT_PUBLIC_SITE_URL=https://sgdi.app
